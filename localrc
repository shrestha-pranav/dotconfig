#!/bin/bash

# Add ~/bin to PATH for custom scripts (e.g., VS Code wrapper)
export PATH="$HOME/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"

# Exec into a running docker container (prompts if more than one)
dux() {
    local containers=($(docker ps --format "{{.Names}}"))

    if [ ${#containers[@]} -eq 0 ]; then
        echo "No running containers found"
        return 1
    elif [ ${#containers[@]} -eq 1 ]; then
        if [ $# -eq 0 ]; then
            docker exec -it "${containers[0]}" bash
        else
            docker exec -it "${containers[0]}" "$@"
        fi
    else
        PS3="Select container: "
        select container in "${containers[@]}"; do
            if [ -n "$container" ]; then
                if [ $# -eq 0 ]; then
                    docker exec -it "$container" bash
                else
                    docker exec -it "$container" "$@"
                fi
                break
            fi
        done
    fi
}

# Switch between git worktrees: `wt` to list, `wt <name>` to cd (supports tab completion)
wt() {
    local base
    base="$(git worktree list --porcelain 2>/dev/null | head -1 | sed 's/^worktree //')" || return 1
    if [[ -z "$1" ]]; then
        git worktree list
        return
    fi
    local match
    match="$(git worktree list --porcelain | awk -v pat="$1" '/^worktree / { p=$2 } p ~ pat && p != "'"$base"'" { print p; exit }')"
    if [[ -n "$match" ]]; then
        cd "$match"
    else
        echo "No worktree matching '$1'" >&2
        return 1
    fi
}
_wt_complete() {
    local base
    base="$(git worktree list --porcelain 2>/dev/null | head -1 | sed 's/^worktree //')"
    COMPREPLY=($(git worktree list --porcelain 2>/dev/null | awk '/^worktree / { print $2 }' | grep -v "^${base}$" | xargs -n1 basename | grep "^${COMP_WORDS[COMP_CWORD]}"))
}
complete -F _wt_complete wt

# Machine-local, secret, and work-specific settings (gitignored, not shared)
test -f ~/.config/.local_aliases && . ~/.config/.local_aliases


# --- Python virtualenvs (uv-managed; all envs live under $VENV_HOME) ---
export VENV_HOME="$HOME/.virtualenvs"

# v [name]: activate a venv by name. Bare `v` lists envs. Exit with `deactivate`.
v() {
    if [ -z "$1" ]; then
        command ls -1 "$VENV_HOME" 2>/dev/null | command grep -viE "^README" || true
        return
    fi
    local act="$VENV_HOME/$1/bin/activate"
    if [ ! -f "$act" ]; then
        echo "v: no venv '$1' in $VENV_HOME (create: mkvenv $1)" >&2
        return 1
    fi
    source "$act"
}
_v_complete() {
    COMPREPLY=($(compgen -W "$(command ls -1 "$VENV_HOME" 2>/dev/null | command grep -viE "^README")" -- "${COMP_WORDS[COMP_CWORD]}"))
}
complete -F _v_complete v

# mkvenv <name> [python-version]: create a uv venv under $VENV_HOME, install ipykernel,
# register it as a global Jupyter kernel, and log a row in the dir README.
mkvenv() {
    [ -z "$1" ] && { echo "usage: mkvenv <name> [python-version]"; return 1; }
    local name="$1" dir="$VENV_HOME/$1"
    [ -e "$dir" ] && { echo "mkvenv: '$name' already exists at $dir" >&2; return 1; }
    uv venv ${2:+--python "$2"} "$dir" || return 1
    uv pip install --python "$dir/bin/python" ipykernel || return 1
    "$dir/bin/python" -m ipykernel install --user --name "$name" --display-name "Python ($name)" || return 1
    local readme="$VENV_HOME/README.md"
    [ -f "$readme" ] || printf "# Virtualenvs (uv-managed)\n\nAll envs live here; activate with \`v <name>\`. Each registers a global Jupyter kernel.\n\n| env | created | python | description |\n|---|---|---|---|\n" > "$readme"
    grep -q "^| \`$name\` " "$readme" 2>/dev/null || \
        printf "| \`%s\` | %s | %s | _describe me_ |\n" "$name" "$(date +%Y-%m-%d)" "$(${dir}/bin/python --version 2>&1 | awk '{print $2}')" >> "$readme"
    echo "mkvenv: created $dir + kernel 'Python ($name)'  ->  activate with: v $name"
}
